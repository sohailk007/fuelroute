# All optional -- the defaults work out of the box.
DJANGO_DEBUG=1
DJANGO_SECRET_KEY=&2x!a7k_n%3-uv1+(c#iz4o*!7eqbz=q3mwh=mep+u+hn*oswa

# Routing provider (any OSRM-compatible endpoint).
OSRM_BASE_URL=https://router.project-osrm.org
HTTP_TIMEOUT=20

# Vehicle / problem parameters
VEHICLE_RANGE_MILES=500
VEHICLE_MPG=10
FUEL_CORRIDOR_MILES=25
ROUTE_SAMPLE_MILES=2

# Enable to allow full street-address geocoding via OpenStreetMap Nominatim.
# Off by default to keep external calls to a minimum (please set a real UA).
NOMINATIM_FALLBACK=0
NOMINATIM_USER_AGENT=fuelroute-demo/1.0 (you@example.com)
